# =====================================================
# CALICCHIA DESIGN PLATFORM — TEMPLATE ENV DI PRODUZIONE
# Copia in `.env` nel progetto Dokploy e compila i valori.
# NON committare mai il .env reale. Generare i segreti con `openssl rand -hex 32`.
# =====================================================

# --- DOMINI (Traefik / Dokploy) ---------------------------------------
SITE_DOMAIN=calicchia.design
ADMIN_DOMAIN=admin.calicchia.design
API_DOMAIN=api.calicchia.design

# --- URL pubblici (derivati dai domini) -------------------------------
API_URL=https://api.calicchia.design
SITE_URL=https://calicchia.design
ADMIN_URL=https://admin.calicchia.design
NEXT_PUBLIC_API_URL=https://api.calicchia.design
VITE_API_URL=https://api.calicchia.design
PUBLIC_SITE_URL=https://calicchia.design
# CORS: domini ammessi a chiamare l'API (OBBLIGATORIO in produzione — l'API
# rifiuta il boot se vuoto).
CORS_ORIGINS=https://calicchia.design,https://admin.calicchia.design

# --- DATABASE ---------------------------------------------------------
# Usati dal servizio postgres del compose; l'API riceve DATABASE_URL costruita.
DB_NAME=caldes
DB_USER=caldes
DB_PASSWORD=__CAMBIA_password_robusta__

# --- AUTH / CRITTOGRAFIA (OBBLIGATORI) --------------------------------
JWT_SECRET=__openssl_rand_hex_32__
WEBHOOK_ENCRYPTION_KEY=__openssl_rand_hex_32__
BOOKING_TOKEN_SECRET=__openssl_rand_hex_32__
ANALYTICS_PEPPER=__openssl_rand_base64_32__
CRON_SECRET=__openssl_rand_hex_32__
# Scoping cookie auth tra sottodomini. Vuoto = host-only (default sicuro).
COOKIE_DOMAIN=

# --- EMAIL — ibrida: Resend (critica) + SMTP Vhosting (standard) ------
RESEND_API_KEY=
EMAIL_FROM_CRITICAL=Calicchia Design <noreply@send.calicchia.design>
EMAIL_FROM=Calicchia Design <mail@calicchia.design>
EMAIL_REPLY_TO=mail@calicchia.design
ADMIN_EMAIL=info@calicchia.design
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# Cifratura AES-256-GCM delle credenziali email salvate nel DB. openssl rand -hex 32
MAIL_ENC_KEY=__openssl_rand_hex_32__

# --- CLOUDFLARE TURNSTILE (anti-bot form pubblici) --------------------
# Site key letta a runtime dal sito via /api/config (RuntimeConfigProvider).
# Anche l'admin SPA la usa, ma li' resta NEXT_PUBLIC_TURNSTILE_SITE_KEY
# come build-arg perche' Vite non ha un runtime server-side.
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Defense in depth: hostnames where i nostri widget Turnstile possono
# legittimamente girare. Il verifier rifiuta i token con hostname mismatch.
# Comma-separated, lowercase. Lascia vuoto per disabilitare il check.
TURNSTILE_ALLOWED_HOSTNAMES=calicchia.design,www.calicchia.design,admin.calicchia.design

# --- GOOGLE MAPS ------------------------------------------------------
# Runtime, consumata dal sito via /api/config.
GOOGLE_MAPS_KEY=

# --- GOOGLE SEARCH CONSOLE --------------------------------------------
# Token di verifica (meta tag) — da Search Console dopo aver aggiunto il dominio
GOOGLE_SITE_VERIFICATION=

# --- ANALYTICS & ERROR TRACKING --------------------------------------
# GA / Mouseflow vengono iniettati a runtime via /api/config: chi pulla
# l'immagine non eredita i tuoi ID, cambio valore = restart container.
GA_MEASUREMENT_ID=
MOUSEFLOW_ID=
BUGSINK_DSN=
NEXT_PUBLIC_BUGSINK_DSN=
PUBLIC_BUGSINK_DSN=
VITE_BUGSINK_DSN=

# --- PAGAMENTI (opzionali — degradano graceful se vuoti) --------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_WEBHOOK_ID=
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=
REVOLUT_API_KEY=
REVOLUT_MODE=live

# --- AI ---------------------------------------------------------------
# LLM principale: Infomaniak (EU/Svizzera, GDPR).
INFOMANIAK_AI_TOKEN=
INFOMANIAK_AI_PRODUCT_ID=
# Fallback / opzionali
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=
# Generazione immagini (admin)
KIE_API_KEY=
UNSPLASH_ACCESS_KEY=

# --- TELEGRAM (agent / notifiche) -------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Autentica il webhook Telegram: registrato come secret_token in setWebhook e
# verificato in constant-time sull'header X-Telegram-Bot-Api-Secret-Token.
# OBBLIGATORIO in produzione (senza, il webhook viene bloccato). openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# --- WHATSAPP (GOWA gateway, opzionale) -------------------------------
GOWA_URL=
GOWA_BASIC_AUTH_USER=
GOWA_BASIC_AUTH_PASS=
GOWA_WEBHOOK_SECRET=
# Device del numero linkato su GOWA (header X-Device-Id)
GOWA_DEVICE_ID=

# --- BACKUP DB (scripts/backup-db.sh) ---------------------------------
BACKUP_DIR=./backups
RETENTION_DAYS=30

# --- MEGA S4 — object storage S3-compatible ---------------------------
# Usato per: (1) consegna al boot dei knowledge base AI gitignored
# (pricing/profile_knowledge_base.md, caricati una volta su s3://$S4_BUCKET/kb/);
# (2) backup off-site di DB e immagini da scripts/backup-db.sh.
S4_ENDPOINT=
S4_REGION=auto
S4_BUCKET=
S4_ACCESS_KEY_ID=
S4_SECRET_ACCESS_KEY=
# Lasciare 'true' salvo che il provider richieda URL virtual-hosted.
S4_FORCE_PATH_STYLE=true
# Dir scrivibile dove l'API scarica i KB. In Docker è già /data/kb (Dockerfile);
# impostare solo se si esegue l'API fuori dal container.
# KB_DIR=/data/kb
# Path degli upload da sincronizzare su S4 nel backup (vedi backup-db.sh).
UPLOAD_DIR=/data/uploads
