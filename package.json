{
  "name": "caldes-2026",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio, admin dashboard and API monorepo",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@caldes/sito-v3",
    "dev:admin": "npm run dev --workspace=@caldes/admin",
    "dev:api": "npm run dev --workspace=@caldes/api",
    "dev:all": "./dev.sh",
    "build": "npm run build --workspaces --if-present",
    "build:sito": "npm run build --workspace=@caldes/sito-v3",
    "build:admin": "npm run build --workspace=@caldes/admin"
  },
  "author": "Federico",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild", "sharp"]
  }
}
