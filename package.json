{
  "name": "calicchia-design-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio, admin dashboard and API monorepo",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@calicchia/sito-v3",
    "dev:admin": "npm run dev --workspace=@calicchia/admin",
    "dev:api": "npm run dev --workspace=@calicchia/api",
    "dev:all": "./dev.sh",
    "build": "npm run build --workspaces --if-present",
    "build:sito": "npm run build --workspace=@calicchia/sito-v3",
    "build:admin": "npm run build --workspace=@calicchia/admin"
  },
  "author": "Federico",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild", "sharp"]
  }
}
