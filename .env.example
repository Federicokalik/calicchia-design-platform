# =====================================================
# CALICCHIA DESIGN PLATFORM - MONOREPO GLOBAL ENV
# Copy this file to .env and fill in your values.
# =====================================================

# SERVER
PORT=3001
NODE_ENV=development

# DATABASE
DATABASE_URL=postgresql://caldes:caldes@localhost:5432/caldes
# Connection pool tuning (optional — defaults shown, sized for a single API replica)
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=20
# DB_POOL_CONNECT_TIMEOUT=10
# DB_POOL_MAX_LIFETIME=1800

# AUTH
JWT_SECRET=change-this-to-a-random-256-bit-secret
# Secret condiviso tra API e container Radicale (caldavServiceAuth middleware).
# I plugin caldes_auth/caldes_storage lo mandano come Bearer sugli endpoint
# interni /api/caldav-backend/*. Generare con: openssl rand -hex 32.
CALDAV_SERVICE_TOKEN=change-this-to-a-random-32-byte-hex

# URLS
API_URL=http://localhost:3001
API_INTERNAL_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:3001
MCP_PUBLIC_URL=http://localhost:3002
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,::1
VITE_API_URL=http://localhost:3001
# Admin (Vite) link al sito pubblico e al portale clienti — inline a build time
# come `import.meta.env.VITE_*`. In CI sono passati come build-args dell'immagine
# admin via GitHub Actions repo variables (vars.VITE_SITE_URL / vars.VITE_PORTAL_URL).
VITE_SITE_URL=http://localhost:3000
VITE_PORTAL_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
ADMIN_URL=http://localhost:5173
SITE_URL=http://localhost:3000
PORTAL_URL=http://localhost:3000
PORTAL_RETURN_BASE_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
# Production with split origins (`calicchia.design` + `api.calicchia.design`)
# needs `.calicchia.design` so portal_token is sent to both the public site and API.
# Leave empty for localhost.
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SITO-V3 ON-DEMAND REVALIDATE
# When the admin publishes/updates a CMS record (blog post, project, service,
# city, glossario, faq), the API calls sito-v3's /api/revalidate to refresh
# sitemap.xml, llms.txt and any page tagged 'sitemap' within seconds (vs the
# default 1-hour ISR window).
# - URL: where to POST. Leave empty in dev to disable (sitemap will still
#   refresh on the regular ISR schedule).
# - TOKEN: shared secret. Use a random 32-byte hex string in production.
#   Must match REVALIDATE_SECRET set in sito-v3's runtime env.
SITO_REVALIDATE_URL=http://localhost:3000/api/revalidate
SITO_REVALIDATE_TOKEN=change-this-to-a-random-32-byte-hex
# Sito-v3 side: same value as SITO_REVALIDATE_TOKEN above. Asymmetric env name
# for readability (API "sends to", sito-v3 "validates against").
REVALIDATE_SECRET=change-this-to-a-random-32-byte-hex

# EMAIL
RESEND_API_KEY=
EMAIL_FROM=Name <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com
# Marketing email (self-hosted platform) — dedicated Resend key + subdomain so
# bulk-send reputation stays isolated from transactional/critical mail. If unset,
# falls back to RESEND_API_KEY / EMAIL_FROM (NOT recommended for production volume).
RESEND_MARKETING_API_KEY=
EMAIL_FROM_MARKETING=Calicchia Design <news@send.calicchia.design>

# Optional: seed the first admin via `pnpm --filter @calicchia/api seed`.
# Set ADMIN_PASSWORD only for that one-time run, then remove it — or skip the
# seed entirely and use the web first-time setup screen (POST /api/auth/setup).
# ADMIN_PASSWORD=
# ADMIN_NAME=Admin

# CLOUDFLARE TURNSTILE (anti-bot — public forms + admin/portal login)
# Sito-v3 legge la site key a runtime via /api/config (TURNSTILE_SITE_KEY).
# Admin (Vite SPA, no server runtime) usa NEXT_PUBLIC_TURNSTILE_SITE_KEY come
# build-arg. Secret key resta solo server-side.
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Defense in depth: hostnames where i nostri widget possono legittimamente
# girare. Il verifier rifiuta i token con hostname mismatch. Comma-separated.
TURNSTILE_ALLOWED_HOSTNAMES=

# GOOGLE MAPS — runtime via /api/config sul sito.
GOOGLE_MAPS_KEY=

# Google Search Console verification token (sito-v3 <meta> tag) — optional
GOOGLE_SITE_VERIFICATION=

# ANALYTICS & ERROR TRACKING
# GA / Mouseflow vengono iniettati a runtime via /api/config: chi pulla
# l'immagine non eredita i tuoi ID, cambio valore = restart container.
GA_MEASUREMENT_ID=
MOUSEFLOW_ID=
PUBLIC_BUGSINK_DSN=
VITE_BUGSINK_DSN=
BUGSINK_DSN=
NEXT_PUBLIC_BUGSINK_DSN=
# Bugsink source map upload (sito-v3). BUILD-TIME ONLY: letto dal plugin Sentry
# durante `next build` per caricare i source map nascosti e rendere leggibili
# gli stack client su Bugsink. NON è una env runtime del container — va passato
# come --build-arg / GitHub secret. Crealo in Bugsink → Settings → Auth Tokens.
# Senza, il build riesce comunque ma l'upload viene saltato.
SENTRY_AUTH_TOKEN=
COMMENTO_URL=

# AUTOMATION / WEBHOOKS
N8N_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Authenticates the Telegram webhook (X-Telegram-Bot-Api-Secret-Token).
# Required in production. Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=
# Generate with: openssl rand -hex 32
WEBHOOK_ENCRYPTION_KEY=<openssl rand -hex 32>

# AI PROVIDERS
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
INFOMANIAK_AI_TOKEN=
INFOMANIAK_AI_PRODUCT_ID=
GOOGLE_AI_API_KEY=
UNSPLASH_ACCESS_KEY=
KIE_API_KEY=

# STORAGE
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=
UPLOAD_DIR=./uploads
# Private files (quote PDFs, receipts, WhatsApp media) — NOT served on /media/*,
# reachable only via signed /api/files/* URLs (SEC-10). Keep it off UPLOAD_DIR.
PRIVATE_UPLOAD_DIR=./private-uploads
# PRIVATE_URL_TTL_DAYS=180
MAX_FILE_SIZE=52428800

# ANALYTICS (cookieless, Umami-like) — server-side HMAC pepper for visitor/visit IDs.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotation invalidates visitor continuity across the whole history. Never commit.
ANALYTICS_PEPPER=

# MaxMind GeoLite2 license key (free on maxmind.com). Geo fallback when Cloudflare
# cf-ipcountry/cf-ipcity headers are absent. Empty = disabled (CF stays primary).
MAXMIND_LICENSE_KEY=
MAXMIND_MMDB_PATH=./data/GeoLite2-City.mmdb

# STRIPE
STRIPE_SECRET_KEY=
# Stripe publishable key (pk_test_ / pk_live_) — runtime via /api/config sul sito.
# Niente NEXT_PUBLIC_ piu': l'immagine resta neutra.
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PAYPAL
# PayPal merchant client_id (uguale lato server + browser SDK). Runtime via
# /api/config sul sito. Override opzionale via PAYPAL_PUBLIC_CLIENT_ID.
PAYPAL_CLIENT_ID=
# PAYPAL_PUBLIC_CLIENT_ID= (opzionale: solo se SDK browser usa client_id diverso da OAuth server)
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
PAYPAL_RETURN_URL=http://localhost:5173/payments?paypal=success
PAYPAL_CANCEL_URL=http://localhost:5173/payments?paypal=cancelled

# REVOLUT
REVOLUT_API_KEY=
REVOLUT_MODE=sandbox

# BOOKING SYSTEM
BOOKING_TOKEN_SECRET=
CONTACT_FORM_EVENT_TYPE=consulenza-gratuita-30min
ORGANIZER_NAME=Federico Calicchia

# WHATSAPP — GOWA gateway (go-whatsapp-web-multidevice on gowa.calicchia.design)
# GOWA_URL: dominio dell'istanza GOWA. Lasciare vuoto per disabilitare la feature.
# GOWA_BASIC_AUTH_USER/PASS: credenziali Basic Auth configurate su GOWA (--basic-auth).
# GOWA_WEBHOOK_SECRET: HMAC SHA256 shared secret (corrisponde a --webhook-secret di GOWA).
# GOWA_DEVICE_ID: jid della sessione attiva (popolato dopo il primo link via UI).
# WHATSAPP_PUBLIC_BASE_URL: URL pubblico dove punta il link "modifica preferenze"
#   nei messaggi outbound (di norma = SITE_URL).
GOWA_URL=
GOWA_BASIC_AUTH_USER=
GOWA_BASIC_AUTH_PASS=
GOWA_WEBHOOK_SECRET=
GOWA_DEVICE_ID=
WHATSAPP_PUBLIC_BASE_URL=

# DEPRECATED — Evolution API (sostituito da GOWA, lasciato per compat fase migrazione)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# MEGA S4 — object storage S3-compatible (opzionale in dev)
# Consegna al boot dei knowledge base AI gitignored (caricati su s3://$S4_BUCKET/kb/)
# e backup off-site di DB + immagini (scripts/backup-db.sh).
# In dev, lasciando vuoto, l'API legge i KB dai file su disco in apps/api/src/lib/agent/.
S4_ENDPOINT=
S4_REGION=auto
S4_BUCKET=
S4_ACCESS_KEY_ID=
S4_SECRET_ACCESS_KEY=
S4_FORCE_PATH_STYLE=true
# KB_DIR= (dir di lettura dei KB; default = apps/api/src/lib/agent/)

# HEADFUL CAPTURE WORKER (Fase 3 — apps/worker)
# Siti dietro login: il worker apre un Chromium headful + noVNC così l'admin
# può fare login manuale e catturare. OFF in dev (richiede xvfb/chromium/noVNC).
# Vedere apps/worker/README.md.
CAPTURE_HEADFUL_ENABLED=false
# Cartella profili Chrome persistenti (cookie di login sopravvivono tra sessioni).
# In Docker è /data/profiles (mount del volume profiles_data).
CAPTURE_PROFILES_DIR=./.data/profiles
# URL pubblico del client noVNC esposto dal worker (l'admin lo apre in una
# nuova scheda). In dev, se il worker gira in locale su :6080:
# http://localhost:6080
CAPTURE_VNC_BASE_URL=http://localhost:6080
# Flag build-time dell'admin (Vite): mostra il pulsante «Apri browser remoto».
# Va come build-arg dell'immagine admin (vedi apps/admin/Dockerfile).
VITE_CAPTURE_HEADFUL_ENABLED=false
