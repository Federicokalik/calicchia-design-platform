# =====================================================
# HONO API - Environment Variables Template
# Copy this file to the root .env and fill in your values.
# =====================================================

PORT=3001
DATABASE_URL=postgresql://caldes:caldes@localhost:5432/caldes
JWT_SECRET=change-this-to-a-random-256-bit-secret-min-32-chars

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
API_URL=http://localhost:3001

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_RETURN_URL=http://localhost:5173/payments?paypal=success
PAYPAL_CANCEL_URL=http://localhost:5173/payments?paypal=cancelled

REVOLUT_API_KEY=
REVOLUT_MODE=sandbox

PERPLEXITY_API_KEY=
OPENAI_API_KEY=
KIE_API_KEY=
UNSPLASH_ACCESS_KEY=

RESEND_API_KEY=
ADMIN_EMAIL=admin@yourdomain.com

CRON_SECRET=your-random-secret-for-cron-jobs
